# Common
*.log
.DS_Store
.idea/
.vscode/

# Rust (lsp/)
target/
# NOTE: lsp/ is a binary crate — `Cargo.lock` MUST be committed for
# reproducible builds. Do not re-add it to this ignore list.

# Node (vscode/)
node_modules/
*.vsix
out/
dist/

# Java / Gradle (intellij/)
# `gradle/wrapper/`, `gradlew`, and `gradlew.bat` are intentionally
# COMMITTED — they are the bootstrap that lets new contributors and CI
# run the build without a system-installed Gradle. Only the local cache
# directory `.gradle/` (with dot) is ignored.
.gradle/
build/
*.iml
# Local artifact cache populated by the gradle-intellij-platform plugin.
.intellijPlatform/

# Local-only
/tmp/
/scratch/
