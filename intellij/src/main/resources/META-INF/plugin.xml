<idea-plugin package="lang.ktav" allow-bundled-update="true">
  <!-- gradle-intellij-platform will patch this with since-build/until-build from build.gradle.kts -->
  <idea-version />

  <id>lang.ktav</id>
  <name>Ktav</name>
  <vendor email="phpcraftdream@gmail.com" url="https://github.com/ktav-lang">Marat K</vendor>

  <description><![CDATA[
    <p>Editor support for the <a href="https://github.com/ktav-lang/spec">Ktav</a>
    plain configuration format.</p>

    <p>Features:</p>
    <ul>
      <li>Native syntax highlighting for <code>.ktav</code> files</li>
      <li>Comment toggle (<code>#</code>)</li>
      <li>Live diagnostics via bundled <a href="https://github.com/ktav-lang/editor/tree/main/lsp">ktav-lsp</a> language server</li>
    </ul>

    <p>Reference Rust crate: <a href="https://github.com/ktav-lang/rust">ktav-lang/rust</a>.
    Other implementations available — see the <a href="https://github.com/ktav-lang/editor">monorepo README</a>.</p>
  ]]></description>

  <depends>com.intellij.modules.platform</depends>

  <extensions defaultExtensionNs="com.intellij">
    <fileType
      name="Ktav"
      implementationClass="lang.ktav.KtavFileType"
      fieldName="INSTANCE"
      language="ktav"
      extensions="ktav" />
    <lang.commenter
      language="ktav"
      implementationClass="lang.ktav.KtavCommenter" />
    <lang.parserDefinition
      language="ktav"
      implementationClass="lang.ktav.KtavParserDefinition" />
    <lang.foldingBuilder
      language="ktav"
      implementationClass="lang.ktav.KtavFoldingBuilder" />

    <!-- Native IntelliJ syntax highlighter for Ktav.
         Always active, works on any IDE without external dependencies. -->
    <lang.syntaxHighlighterFactory
      language="ktav"
      implementationClass="lang.ktav.highlighting.KtavSyntaxHighlighterFactory" />

    <!-- Settings UI: Tools -> Ktav. Allows override of bundled ktav-lsp path. -->
    <applicationConfigurable
      parentId="tools"
      instance="lang.ktav.lsp.KtavConfigurable"
      id="lang.ktav.settings"
      displayName="Ktav" />
    <applicationService
      serviceImplementation="lang.ktav.lsp.KtavSettings" />
    <applicationService
      serviceImplementation="lang.ktav.lsp.DiagnosticsHolder" />
    <notificationGroup
      id="Ktav"
      displayType="BALLOON" />

    <!-- Built-in LSP client (per-project) -->
    <projectService
      serviceImplementation="lang.ktav.lsp.KtavLspProjectService" />

    <!-- Startup activity: starts LSP and syncs already-open files. Critical for
         dynamic plugin loading where FileEditorManagerListener misses pre-open files. -->
    <postStartupActivity
      implementation="lang.ktav.lsp.KtavStartupActivity" />

    <!-- Live diagnostics from LSP server -->
    <externalAnnotator
      language="ktav"
      implementationClass="lang.ktav.lsp.KtavDiagnosticsAnnotator" />
  </extensions>

  <!-- Format action: replaces standard `Reformat Code` for .ktav files
       (delegates to LSP textDocument/formatting → ktav::render). -->
  <actions>
    <action
      id="lang.ktav.FormatDocument"
      class="lang.ktav.lsp.KtavFormatAction"
      text="Reformat Ktav File"
      description="Reformat the current .ktav file via the language server">
      <keyboard-shortcut keymap="$default" first-keystroke="control alt L" />
      <add-to-group group-id="EditorPopupMenu" anchor="last" />
    </action>
  </actions>

  <!-- File editor lifecycle listener: starts LSP client and syncs documents -->
  <projectListeners>
    <listener
      class="lang.ktav.lsp.FileOpenListener"
      topic="com.intellij.openapi.fileEditor.FileEditorManagerListener" />
  </projectListeners>
</idea-plugin>
