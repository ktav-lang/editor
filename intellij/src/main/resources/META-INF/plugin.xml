<idea-plugin package="lang.ktav" allow-bundled-update="true">
  <!-- gradle-intellij-platform will patch this with since-build/until-build from build.gradle.kts -->
  <idea-version />

  <id>lang.ktav</id>
  <name>Ktav</name>
  <vendor email="phpcraftdream@gmail.com" url="https://github.com/ktav-lang">Marat K</vendor>

  <description><![CDATA[
    <p>Editor support for the <a href="https://github.com/ktav-lang/spec">Ktav</a>
    plain configuration format.</p>

    <p>Features:</p>
    <ul>
      <li>Syntax highlighting for <code>.ktav</code> files via TextMate grammar</li>
      <li>Comment toggle (<code>#</code>)</li>
      <li>Bracket matching for <code>{}</code> <code>[]</code> <code>()</code></li>
      <li>Live diagnostics via <a href="https://github.com/ktav-lang/editor/tree/main/lsp">ktav-lsp</a> (when installed in PATH; configurable in settings)</li>
    </ul>

    <p>Reference Rust crate: <a href="https://github.com/ktav-lang/rust">ktav-lang/rust</a>.
    Other implementations available — see the <a href="https://github.com/ktav-lang/editor">monorepo README</a>.</p>
  ]]></description>

  <!-- change-notes: single source of truth is CHANGELOG.md, wired via
       `intellijPlatform.pluginConfiguration.changeNotes` in build.gradle.kts -->

  <depends>com.intellij.modules.platform</depends>
  <depends>org.jetbrains.plugins.textmate</depends>

  <extensions defaultExtensionNs="com.intellij">
    <fileType
      name="Ktav"
      implementationClass="lang.ktav.KtavFileType"
      fieldName="INSTANCE"
      language="ktav"
      extensions="ktav" />
    <lang.commenter
      language="ktav"
      implementationClass="lang.ktav.KtavCommenter" />

    <!-- Native IntelliJ syntax highlighter for Ktav.
         Works on any IDE without external dependencies.
         LSP4IJ can optionally provide semantic token highlighting if installed separately. -->
    <lang.syntaxHighlighterFactory
      language="ktav"
      implementationClass="lang.ktav.highlighting.KtavSyntaxHighlighterFactory" />

    <!-- Settings UI is registered unconditionally so users can configure
         the ktav-lsp path even before LSP4IJ is installed (the value is
         persisted and consumed by KtavLanguageServerFactory once LSP4IJ
         loads). -->
    <applicationConfigurable
      parentId="tools"
      instance="lang.ktav.lsp.KtavConfigurable"
      id="lang.ktav.settings"
      displayName="Ktav" />
    <applicationService
      serviceImplementation="lang.ktav.lsp.KtavSettings" />
    <notificationGroup
      id="Ktav"
      displayType="BALLOON" />

    <!-- LSP client services -->
    <projectService
      serviceImplementation="lang.ktav.lsp.KtavLspProjectService" />
    <fileEditorManagerListener
      implementation="lang.ktav.lsp.FileOpenListener" />
  </extensions>

  <!-- TextMate auto-registration disabled: internal API, breaks IDE state
       Users can manually register bundle via Settings → Editor → TextMate Bundles
       if TextMate syntax highlighting is desired alongside native highlighter.
  <applicationListeners>
    <listener
      class="lang.ktav.KtavTextMateLoader"
      topic="com.intellij.ide.AppLifecycleListener" />
    <listener
      class="lang.ktav.KtavProjectActivity"
      topic="com.intellij.openapi.project.ProjectManagerListener" />
  </applicationListeners> -->
</idea-plugin>
