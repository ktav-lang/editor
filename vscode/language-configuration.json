{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" }
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(?:.*[:]\\s+[\\{\\[\\(]|[\\{\\[\\(])\\s*$",
    "decreaseIndentPattern": "^\\s*[\\}\\]\\)]\\s*$"
  },
  "onEnterRules": [
    {
      "beforeText": "^\\s*(?:.*[:]\\s+\\(\\(|\\(\\()\\s*$",
      "action": { "indent": "indent" }
    },
    {
      "beforeText": "^\\s*(?:.*[:]\\s+\\(|\\()\\s*$",
      "action": { "indent": "indent" }
    },
    {
      "beforeText": "^\\s*(?:.*[:]\\s+[\\{\\[]|[\\{\\[])\\s*$",
      "action": { "indent": "indent" }
    }
  ],
  "wordPattern": "[^\\s\\[\\]{}:#.]+"
}
