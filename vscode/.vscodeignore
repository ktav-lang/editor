.vscode/
.gitignore
.gitkeep
**/.gitkeep
# Keep node_modules — vscode-languageclient is a runtime dependency
node_modules/.bin/
node_modules/*/README
node_modules/*/*.map
node_modules/*/.bin/
out/**/*.map
src/**
tsconfig.json
scripts/
scripts/sync-grammars.js
**/*.ts
!out/**/*.js
out/test/**

# ---------------------------------------------------------------------------
# Per-platform native binaries
# ---------------------------------------------------------------------------
# Include all per-platform native binaries in the VSIX
# (vscode-languageclient will select the right one at runtime via discovery.ts)
